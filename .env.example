# Copy this to .env and fill in your values
FOOL_EMAIL=your_email@example.com
FOOL_PASSWORD=your_password

# Email settings (Gmail with App Password recommended)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
RECIPIENT_EMAIL=your_email@gmail.com

# Robinhood (read-only portfolio access)
ROBINHOOD_EMAIL=your_robinhood_email
ROBINHOOD_PASSWORD=your_robinhood_password
# TOTP secret for auto-generating MFA codes (from authenticator app setup)
ROBINHOOD_TOTP_SECRET=

# Optional: Claude API for AI synthesis
ANTHROPIC_API_KEY=

# Optional: Additional data sources
ALPHA_VANTAGE_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
